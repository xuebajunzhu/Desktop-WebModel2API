{
  "name": "web2api-desktop",
  "version": "1.0.0",
  "description": "Web2API Desktop - Turn web LLM chats into unified HTTP APIs",
  "main": "src/main/index.ts",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "build": "tsc && vite build",
    "package": "electron-builder",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "llm",
    "api",
    "chatgpt",
    "claude",
    "electron",
    "playwright"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vite-plugin-electron": "^0.28.1"
  },
  "dependencies": {
    "better-sqlite3": "^9.2.2",
    "express": "^4.18.2",
    "playwright": "^1.40.1",
    "playwright-stealth": "^1.0.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.0",
    "uuid": "^9.0.1",
    "yaml": "^2.3.4"
  },
  "build": {
    "appId": "com.web2api.desktop",
    "productName": "Web2API",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    }
  }
}
